<!DOCTYPE html><html class="dark" lang="en" style=""><head>
<meta charset="utf-8">
<meta content="width=device-width, initial-scale=1.0" name="viewport">
<title>Le Tour - My Team Management</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;800&amp;family=Inter:wght@400;700&amp;family=JetBrains+Mono:wght@500;700&amp;family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@100..900&amp;family=Inter:wght@100..900&amp;display=swap" rel="stylesheet">
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .tricolor-ribbon {
            background: linear-gradient(to right, #002395 33.3%, #ffffff 33.3%, #ffffff 66.6%, #ed2939 66.6%);
        }
        .asphalt-gradient {
            background: linear-gradient(135deg, #1e1e22 0%, #131315 100%);
        }
        .topographic-pattern {
            background-image: radial-gradient(#3f3f46 0.5px, transparent 0.5px);
            background-size: 24px 24px;
            opacity: 0.1;
        }
    </style>
<!-- Tailwind Config Execution -->
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "inverse-surface": "#e5e1e4",
                    "outline-variant": "#4c4732",
                    "on-error-container": "#ffdad6",
                    "primary-container": "#ffe000",
                    "primary-fixed-dim": "#e2c600",
                    "tertiary-container": "#ffd7d8",
                    "tertiary-fixed-dim": "#ffb3b6",
                    "on-error": "#690005",
                    "background": "#131315",
                    "surface-tint": "#e2c600",
                    "surface": "#131315",
                    "surface-container-highest": "#353437",
                    "surface-container-lowest": "#0e0e10",
                    "surface-container-high": "#2a2a2c",
                    "on-tertiary-fixed": "#40000c",
                    "on-tertiary": "#68001a",
                    "on-primary": "#383000",
                    "error": "#ffb4ab",
                    "tertiary": "#fffcff",
                    "primary-fixed": "#ffe33b",
                    "secondary": "#75dc8b",
                    "on-background": "#e5e1e4",
                    "on-primary-container": "#716300",
                    "on-primary-fixed-variant": "#524700",
                    "primary": "#fffcff",
                    "secondary-fixed": "#91f9a4",
                    "on-secondary-fixed-variant": "#005323",
                    "surface-dim": "#131315",
                    "on-secondary-container": "#c2ffc8",
                    "error-container": "#93000a",
                    "on-primary-fixed": "#211b00",
                    "on-secondary": "#003916",
                    "inverse-primary": "#6c5e00",
                    "on-secondary-fixed": "#00210a",
                    "surface-bright": "#39393b",
                    "on-tertiary-fixed-variant": "#920028",
                    "inverse-on-surface": "#303032",
                    "secondary-container": "#007e39",
                    "surface-container": "#201f21",
                    "surface-container-low": "#1b1b1d",
                    "on-tertiary-container": "#c7003a",
                    "secondary-fixed-dim": "#75dc8b",
                    "surface-variant": "#353437",
                    "on-surface": "#e5e1e4",
                    "outline": "#979177",
                    "on-surface-variant": "#cec6ab",
                    "tertiary-fixed": "#ffdada"
            },
            "borderRadius": {
                    "DEFAULT": "0.125rem",
                    "lg": "0.25rem",
                    "xl": "0.5rem",
                    "full": "0.75rem"
            },
            "spacing": {
                    "lg": "24px",
                    "md": "16px",
                    "margin-desktop": "32px",
                    "xl": "32px",
                    "base": "4px",
                    "xs": "4px",
                    "gutter": "16px",
                    "sm": "8px",
                    "margin-mobile": "16px"
            },
            "fontFamily": {
                    "headline-md": ["Barlow Condensed"],
                    "headline-sm": ["Barlow Condensed"],
                    "display-lg": ["Barlow Condensed"],
                    "stat-sm": ["JetBrains Mono"],
                    "body-lg": ["Inter"],
                    "body-md": ["Inter"],
                    "stat-lg": ["JetBrains Mono"],
                    "display-lg-mobile": ["Barlow Condensed"],
                    "label-caps": ["Barlow Condensed"]
            },
            "fontSize": {
                    "headline-md": ["24px", {"lineHeight": "30px", "letterSpacing": "-0.01em", "fontWeight": "700"}],
                    "headline-sm": ["20px", {"lineHeight": "24px", "fontWeight": "700"}],
                    "display-lg": ["48px", {"lineHeight": "52px", "letterSpacing": "-0.01em", "fontWeight": "800"}],
                    "stat-sm": ["14px", {"lineHeight": "20px", "fontWeight": "500"}],
                    "body-lg": ["18px", {"lineHeight": "28px", "fontWeight": "400"}],
                    "body-md": ["16px", {"lineHeight": "24px", "fontWeight": "400"}],
                    "stat-lg": ["32px", {"lineHeight": "36px", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                    "display-lg-mobile": ["36px", {"lineHeight": "40px", "fontWeight": "800"}],
                    "label-caps": ["13px", {"lineHeight": "16px", "letterSpacing": "0.08em", "fontWeight": "700"}]
            }
          },
        },
      }
    </script>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen pb-32">
<!-- TopAppBar from JSON -->
<header class="w-full top-0 sticky bg-surface dark:bg-surface border-b border-outline-variant dark:border-outline-variant z-50">
<div class="flex justify-between items-center px-margin-mobile py-sm w-full"><div class="flex items-center gap-sm"><span class="material-symbols-outlined text-primary">leaderboard</span><div class="flex flex-col"><h1 class="font-display-lg text-display-lg-mobile uppercase tracking-tighter text-primary">LE TOUR</h1><div class="flex items-center gap-xs -mt-1"><p class="font-label-caps text-[14px] text-on-surface-variant">LES BLEUS</p><button class="text-on-surface-variant hover:text-primary transition-colors"><span class="material-symbols-outlined text-[14px]">edit</span></button></div></div></div></div>
</header>
<main class="relative px-margin-mobile pt-lg max-w-4xl mx-auto">
<div class="absolute inset-0 topographic-pattern pointer-events-none"></div>
<!-- Budget Section -->
<section class="mb-xl relative z-10">
<div class="flex justify-between items-end mb-sm"><h2 class="font-headline-md text-headline-md text-primary uppercase">Financials</h2><div class="flex items-center gap-md"><button class="font-label-caps text-on-surface-variant hover:text-error transition-colors border border-outline-variant/30 px-sm py-1 rounded">CLEAR ROSTER</button><div class="font-stat-sm text-stat-sm text-on-surface-variant">BUDGET CAP: 100M</div></div></div>
<div class="bg-surface-container p-lg rounded-xl border border-outline-variant">
<div class="w-full h-4 bg-surface-container-highest rounded-full overflow-hidden flex mb-md">
<div class="h-full bg-primary-container" style="width: 85%"></div>
</div>
<div class="grid grid-cols-2 gap-gutter">
<div class="space-y-xs">
<p class="font-label-caps text-label-caps text-on-surface-variant">SPENT</p>
<p class="font-stat-lg text-stat-lg text-primary">85.0M</p>
</div>
<div class="space-y-xs text-right">
<p class="font-label-caps text-label-caps text-on-surface-variant">REMAINING</p>
<p class="font-stat-lg text-stat-lg text-secondary">15.0M</p>
</div>
</div>
</div>
</section>
<!-- Roster Section -->
<section class="space-y-md relative z-10">
<div class="flex justify-between items-center px-xs">
<h2 class="font-headline-md text-headline-md text-primary uppercase">Active Roster</h2>
<span class="font-label-caps text-on-surface-variant">9 / 9 RIDERS</span>
</div>
<!-- Captain Card -->
<div class="asphalt-gradient border border-primary-container rounded-xl overflow-hidden relative active:scale-[0.98] transition-transform">
<div class="tricolor-ribbon h-1 w-full"></div>
<div class="absolute top-0 right-0 p-md">
<div class="bg-primary-container text-on-primary-container px-sm py-xs rounded flex items-center gap-xs">
<span class="material-symbols-outlined text-[16px]" style="font-variation-settings: 'FILL' 1;">star</span>
<span class="font-label-caps text-[11px]">2X CAPTAIN</span>
</div>
</div>
<div class="p-lg flex gap-lg items-center"><div class="flex-1"><div class="flex items-center gap-sm mb-xs"><h3 class="font-headline-sm text-headline-sm text-primary uppercase">Jonas Vingegaard</h3><span class="material-symbols-outlined text-primary-container text-[20px]" title="Yellow Jersey Leader">apparel</span></div><p class="text-[11px] font-label-caps text-on-surface-variant mb-xs">Team Visma | Lease a Bike</p><div class="flex gap-md mt-xs"><span class="font-label-caps text-on-surface-variant bg-surface-container px-sm py-[2px] rounded">CLIMBER</span><span class="font-stat-sm text-stat-sm text-primary-container font-bold">14.2M</span></div></div><div class="text-right hidden sm:block"><p class="font-label-caps text-on-surface-variant">LAST SCORE</p><p class="font-stat-lg text-stat-lg text-primary">124 <span class="text-primary-container">x2</span></p></div></div>
<div class="border-t border-outline-variant/30 px-lg py-sm flex justify-between items-center bg-primary-container/5"><div class="flex gap-lg"><div><p class="text-[10px] font-label-caps text-on-surface-variant uppercase">Last Race</p><p class="font-stat-sm text-stat-sm text-primary">124</p></div><div><p class="text-[10px] font-label-caps text-on-surface-variant uppercase">Total Points</p><p class="font-stat-sm text-stat-sm text-primary">1,402</p></div></div><button class="bg-surface-variant hover:bg-error transition-colors px-md py-sm rounded-lg flex items-center gap-sm group"><span class="material-symbols-outlined text-[18px] group-hover:text-white">logout</span><span class="font-label-caps text-on-surface group-hover:text-white">DROP</span></button></div>
</div>
<!-- Player Card 2 -->
<div class="asphalt-gradient border border-outline-variant rounded-xl overflow-hidden relative">
<div class="tricolor-ribbon h-1 w-full opacity-30"></div>
<div class="p-lg flex gap-lg items-center"><div class="flex-1"><div class="flex items-center gap-sm mb-xs"><h3 class="font-headline-sm text-headline-sm text-primary uppercase">Jasper Philipsen</h3><span class="material-symbols-outlined text-secondary text-[20px]" title="Green Jersey Leader">apparel</span></div><p class="text-[11px] font-label-caps text-on-surface-variant mb-xs">Alpecin-Deceuninck</p><div class="flex gap-md mt-xs"><span class="font-label-caps text-on-surface-variant bg-surface-container px-sm py-[2px] rounded">SPRINTER</span><span class="font-stat-sm text-stat-sm text-primary font-bold">11.8M</span></div></div><div class="text-right hidden sm:block"><p class="font-label-caps text-on-surface-variant">LAST SCORE</p><p class="font-stat-lg text-stat-lg text-primary">98</p></div></div>
<div class="border-t border-outline-variant/30 px-lg py-sm flex justify-between items-center"><div class="flex gap-lg"><div><p class="text-[10px] font-label-caps text-on-surface-variant uppercase">Last Race</p><p class="font-stat-sm text-stat-sm text-primary">124</p></div><div><p class="text-[10px] font-label-caps text-on-surface-variant uppercase">Total Points</p><p class="font-stat-sm text-stat-sm text-primary">1,402</p></div></div><button class="bg-surface-variant hover:bg-error transition-colors px-sm py-xs rounded flex items-center gap-xs group"><span class="material-symbols-outlined text-[16px] group-hover:text-white">logout</span><span class="font-label-caps text-[11px] text-on-surface group-hover:text-white">DROP</span></button></div>
</div>
<!-- Player Card 3 -->
<div class="asphalt-gradient border border-outline-variant rounded-xl overflow-hidden relative">
<div class="tricolor-ribbon h-1 w-full opacity-30"></div>
<div class="p-lg flex gap-lg items-center"><div class="flex-1"><h3 class="font-headline-sm text-headline-sm text-primary uppercase mb-xs">Wout Van Aert</h3><p class="text-[11px] font-label-caps text-on-surface-variant mb-xs">Team Visma | Lease a Bike</p><div class="flex gap-md mt-xs"><span class="font-label-caps text-on-surface-variant bg-surface-container px-sm py-[2px] rounded">ALL-ROUNDER</span><span class="font-stat-sm text-stat-sm text-primary font-bold">12.5M</span></div></div><div class="text-right hidden sm:block"><p class="font-label-caps text-on-surface-variant">LAST SCORE</p><p class="font-stat-lg text-stat-lg text-primary">112</p></div></div>
<div class="border-t border-outline-variant/30 px-lg py-sm flex justify-between items-center"><div class="flex gap-lg"><div><p class="text-[10px] font-label-caps text-on-surface-variant uppercase">Last Race</p><p class="font-stat-sm text-stat-sm text-primary">98</p></div><div><p class="text-[10px] font-label-caps text-on-surface-variant uppercase">Total Points</p><p class="font-stat-sm text-stat-sm text-primary">856</p></div></div><div class="flex gap-sm"><button class="bg-surface-variant hover:bg-primary-container hover:text-on-primary-container transition-all px-sm py-xs rounded flex items-center gap-xs"><span class="material-symbols-outlined text-[16px]">star</span><span class="font-label-caps text-[11px]">CAPTAIN</span></button><button class="p-xs text-on-surface-variant hover:text-error transition-colors"><span class="material-symbols-outlined text-[18px]">delete</span></button></div></div>
</div>
<!-- Empty Slot State -->
<button class="w-full border-2 border-dashed border-outline-variant rounded-xl p-xl flex flex-col items-center justify-center gap-sm hover:border-primary-container transition-colors group">
<div class="w-12 h-12 rounded-full bg-surface-container-high flex items-center justify-center group-hover:bg-primary-container group-hover:text-on-primary-container transition-colors">
<span class="material-symbols-outlined">add</span>
</div>
<span class="font-headline-sm text-on-surface-variant uppercase">Add Rider to Roster</span>
</button>
</section>
</main>
<!-- Bottom Navigation from JSON -->
<nav class="fixed bottom-0 left-0 w-full flex justify-around items-center px-margin-mobile pb-sm pt-xs bg-surface-container dark:bg-surface-container border-t border-outline-variant dark:border-outline-variant z-50">
<a class="flex flex-col items-center justify-center text-on-surface-variant dark:text-on-surface-variant px-lg py-xs hover:bg-surface-container-high dark:hover:bg-surface-container-high transition-colors" href="#">
<span class="material-symbols-outlined">home</span>
<span class="font-label-caps text-label-caps mt-xs">Home</span>
</a>
<!-- Active Tab: My Team -->
<a class="flex flex-col items-center justify-center bg-primary-container dark:bg-primary-container text-on-primary-container dark:text-on-primary-container rounded-full px-lg py-xs active:scale-90 transition-all duration-150" href="#">
<span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">directions_bike</span>
<span class="font-label-caps text-label-caps mt-xs">My Team</span>
</a>
<a class="flex flex-col items-center justify-center text-on-surface-variant dark:text-on-surface-variant px-lg py-xs hover:bg-surface-container-high dark:hover:bg-surface-container-high transition-colors" href="#">
<span class="material-symbols-outlined">group</span>
<span class="font-label-caps text-label-caps mt-xs">Players</span>
</a>
</nav>
<!-- Micro-interaction script -->
<script>
        document.querySelectorAll('button').forEach(button => {
            button.addEventListener('mousedown', () => {
                button.classList.add('scale-95');
            });
            button.addEventListener('mouseup', () => {
                button.classList.remove('scale-95');
            });
            button.addEventListener('mouseleave', () => {
                button.classList.remove('scale-95');
            });
        });
    </script>


</body></html>